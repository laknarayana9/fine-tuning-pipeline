# Copy to .env locally when you are ready for intentional model calls.
# Never commit real keys.

# Required gate for any network/model provider in this repo.
ALLOW_MODEL_CALLS=0

# Fireworks OpenAI-compatible endpoint.
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=

# Optional alias if using a generic OpenAI-compatible provider.
OPENAI_API_KEY=
